{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "description": "URL to user's profile picture." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." },
        "subscription": { "type": "string", "enum": ["free", "pro"], "description": "User's subscription tier." },
        "messageCount": { "type": "integer", "description": "Total messages sent by the user." },
        "preferences": {
          "type": "object",
          "properties": {
            "notifications": { "type": "boolean" },
            "language": { "type": "string" },
            "publicProfile": { "type": "boolean" },
            "dataTraining": { "type": "boolean" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "Represents a conversation thread.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message within a chat session.",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "video", "audio"] },
        "mediaUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sessionId", "role", "content", "type"]
    },
    "Memory": {
      "title": "Long-term Memory",
      "description": "Stores facts and preferences about the user for long-term memory.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fact": { "type": "string", "description": "The piece of information to remember." },
        "category": { "type": "string", "description": "e.g., 'preference', 'personal_info', 'history'" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "fact"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/users/{userId}/memories/{memoryId}": {
      "schema": "Memory",
      "description": "User's long-term memory bank."
    },
    "/sessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Chat session metadata."
    },
    "/sessions/{sessionId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a session."
    }
  }
}
